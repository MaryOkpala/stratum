upstream stratum_app {
    server {{ hostvars['app']['ansible_host'] }}:8080;
    keepalive 32;
}

server {
    listen 80;
    server_name _;

    access_log /var/log/nginx/stratum_access.log;
    error_log  /var/log/nginx/stratum_error.log;

    location /health {
        return 200 'Stratum web tier healthy\n';
        add_header Content-Type text/plain;
    }

    location / {
        proxy_pass         http://stratum_app;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_connect_timeout 30s;
        proxy_send_timeout    30s;
        proxy_read_timeout    30s;
    }
}
